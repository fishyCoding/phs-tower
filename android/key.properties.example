# Template for android/key.properties (the real file is gitignored).
#
# 1. Generate a release keystore (keep the .jks file and these passwords safe —
#    losing them means you can never update the published app):
#
#      keytool -genkey -v -keystore phs-tower-release.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias phs-tower
#
# 2. Copy this file to android/key.properties and fill in the real values.
# 3. Register the keystore's SHA-1 in the Android OAuth client:
#
#      keytool -list -v -keystore phs-tower-release.jks -alias phs-tower
#
storeFile=/absolute/path/to/phs-tower-release.jks
storePassword=CHANGE_ME
keyAlias=phs-tower
keyPassword=CHANGE_ME
